<Window x:Class="POS.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:POS.Wpf.Converters"
        Title="SmartPOS" Height="760" Width="1280" MinWidth="960" MinHeight="580"
        Background="{DynamicResource BgSecondaryBrush}"
        FlowDirection="{Binding UiFlowDirection}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="F2"  Command="{Binding PriceCheckCommand}"/>
        <KeyBinding Key="F3"  Command="{Binding HoldResumeCommand}"/>
        <KeyBinding Key="F5"  Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="F11" Command="{Binding ToggleFullscreenCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Converters -->
        <conv:FilePathToImageConverter    x:Key="FileToImg"/>
        <conv:StringToInitialsConverter   x:Key="ToInitials"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:ImagePathToVisibilityConverter   x:Key="HasImageVis"/>
        <conv:ImagePathToVisibilityConverter   x:Key="NoImageVis" Inverted="True"/>
        <conv:LowStockToVisibilityConverter    x:Key="LowStockVis"/>
        <BooleanToVisibilityConverter          x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════
         Root: Sidebar | Main
    ══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT SIDEBAR (light surface) ═══ -->
        <Border Grid.Column="0"
                Background="{DynamicResource BgPrimaryBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0.5,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top"
                        Height="56"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0,0,0,0.5">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Line X1="5" Y1="8"  X2="23" Y2="8"  Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="5" Y1="14" X2="17" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="5" Y1="20" X2="11" Y2="20" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Ellipse Width="8" Height="8" Canvas.Left="17" Canvas.Top="16" Fill="White" Opacity="0.9"/>
                        </Canvas>
                    </Border>
                </Border>

                <!-- Bottom: Logout -->
                <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button Command="{Binding DataContext.GoHomeCommand,
                                     RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="{Binding NavLogoutLabel}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconLogout}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavLogoutLabel}" FontSize="9" FontWeight="Medium"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0">

                    <!-- Home / Cashier -->
                    <Button Command="{Binding GoHomeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Cashier">
                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconHome}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavHomeLabel}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Customers -->
                    <Button Command="{Binding GoCustomersCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Customers">
                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconCustomers}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavCustomersLabel}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Orders -->
                    <Button Command="{Binding GoOrdersCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Orders">
                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconOrders}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavOrdersLabel}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Products (Admin) -->
                    <Button Command="{Binding GoProductsCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Products">
                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconProducts}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavProductsLabel}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Reports (Admin) -->
                    <Button Command="{Binding GoReportsCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Reports">
                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconReports}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavReportsLabel}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <Button Command="{Binding GoSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Settings">
                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,0,2">
                                <Path Data="{StaticResource IconSettings}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NavSettingsLabel}" FontSize="9" FontWeight="Medium" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN AREA ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>    <!-- Topbar -->
                <RowDefinition Height="38"/>    <!-- Invoice tabs -->
                <RowDefinition Height="*"/>     <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ─── TOPBAR ─── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgPrimaryBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,0,0,0.5">
                <Grid Margin="16,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- Brand -->
                        <ColumnDefinition Width="*"/>      <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>   <!-- Controls -->
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                        <Run Text="Smart" FontSize="17" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Run Text="POS"   FontSize="17" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}"/>
                    </TextBlock>

                    <!-- Right controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0">

                        <!-- Online status -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OnlineLabel}" FontSize="11" Margin="5,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Status text -->
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,14,0"
                                   MaxWidth="180" TextTrimming="CharacterEllipsis"/>

                        <!-- Refresh (F5) -->
                        <Button Style="{StaticResource TopBarIconButton}"
                                Margin="0,0,4,0"
                                Command="{Binding RefreshCommand}"
                                ToolTip="{Binding RefreshToolTip}">
                            <Viewbox Width="15" Height="15">
                                <Path Data="{StaticResource IconRefresh}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                        </Button>

                        <!-- Customer display -->
                        <ToggleButton Style="{StaticResource TopBarToggleButton}"
                                      Margin="0,0,4,0"
                                      IsChecked="{Binding CustomerDisplayOpen}"
                                      Command="{Binding ToggleCustomerDisplayCommand}"
                                      ToolTip="{Binding CustomerDisplayToolTip}">
                            <Viewbox Width="15" Height="15">
                                <Path Data="{StaticResource IconMonitor}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                        </ToggleButton>

                        <!-- Price check (F2) -->
                        <Button Style="{StaticResource TopBarIconButton}"
                                Margin="0,0,4,0"
                                Command="{Binding PriceCheckCommand}"
                                ToolTip="{Binding PriceCheckToolTip}">
                            <Viewbox Width="15" Height="15">
                                <Path Data="{StaticResource IconTag}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                        </Button>

                        <!-- Show/hide product images -->
                        <ToggleButton Style="{StaticResource TopBarToggleButton}"
                                      Margin="0,0,4,0"
                                      IsChecked="{Binding ShowProductImages}"
                                      ToolTip="{Binding ToggleImagesToolTip}">
                            <TextBlock FontSize="13">🖼</TextBlock>
                        </ToggleButton>

                        <!-- Dark mode toggle -->
                        <ToggleButton Style="{StaticResource TopBarToggleButton}"
                                      Margin="0,0,8,0"
                                      IsChecked="{Binding IsDarkMode}"
                                      Command="{Binding ToggleDarkModeCommand}"
                                      ToolTip="{Binding ToggleDarkModeToolTip}">
                            <Viewbox Width="14" Height="14">
                                <Path Data="{StaticResource IconMoon}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Stretch="Fill"/>
                            </Viewbox>
                        </ToggleButton>

                        <!-- Hold Orders button -->
                        <Button Height="36" Margin="0,0,10,0"
                                Command="{Binding HoldResumeCommand}"
                                ToolTip="{Binding HoldOrdersToolTip}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PosButtonBase}">
                                    <Setter Property="Background"       Value="Transparent"/>
                                    <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="BorderBrush"      Value="{DynamicResource InputBorderBrush}"/>
                                    <Setter Property="BorderThickness"  Value="0.5"/>
                                    <Setter Property="Padding"          Value="12,0"/>
                                    <Setter Property="FontWeight"       Value="Medium"/>
                                    <Setter Property="FontSize"         Value="13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bdr"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                                                <Path Data="{StaticResource IconPause}"
                                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                      Stretch="Fill"/>
                                                            </Viewbox>
                                                            <TextBlock Text="{Binding DataContext.HoldOrdersLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="{TemplateBinding Foreground}"
                                                                       FontSize="{TemplateBinding FontSize}"
                                                                       FontWeight="{TemplateBinding FontWeight}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <!-- Held count badge -->
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,-7,-7,0"
                                                                Width="18" Height="18"
                                                                CornerRadius="9"
                                                                Background="{DynamicResource AccentBrush}"
                                                                Visibility="{Binding HeldTabCount,
                                                                    Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding HeldTabCount}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- User profile chip -->
                        <Border Height="40"
                                Background="{DynamicResource BgPrimaryBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0.5"
                                CornerRadius="8"
                                Padding="5,5,10,5"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <!-- Avatar circle (blue) -->
                                <Border Width="30" Height="30" CornerRadius="15"
                                        Background="{DynamicResource InfoBgBrush}">
                                    <TextBlock Text="{Binding UserBadge}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InfoBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Name + Role -->
                                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UserName}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding RoleName}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── INVOICE TABS BAR ─── -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BgPrimaryBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,0,0,0.5">
                <Grid Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Scrollable tab strip -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding InvoiceTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Tab button -->
                                    <Border Margin="0,0,2,0" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SwitchTabCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0.5,0.5,0.5,0"/>
                                                <Setter Property="CornerRadius" Value="5,5,0,0"/>
                                                <Setter Property="Padding" Value="10,5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">

                                            <!-- Status dot (green=active, amber=held, gray=inactive) -->
                                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource InputBorderBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsHeld}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource WarnBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!-- Tab label -->
                                            <TextBlock FontSize="12" FontWeight="Medium" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsHeld}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource WarnBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding Label}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding ItemCount}"/>
                                                <Run Text=")"/>
                                            </TextBlock>

                                            <!-- Close × -->
                                            <Button Width="16" Height="16" Margin="6,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource TextTertiaryBrush}"
                                                    FontSize="13" Content="×"
                                                    VerticalContentAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    Cursor="Hand"
                                                    FocusVisualStyle="{x:Null}"
                                                    Command="{Binding DataContext.CloseTabCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bdr" Background="{TemplateBinding Background}"
                                                                CornerRadius="3" Padding="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource DangerBgBrush}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- + New Invoice -->
                    <Button Grid.Column="1" Height="28"
                            Command="{Binding NewSaleCommand}"
                            VerticalAlignment="Center" Margin="4,0,0,0"
                            Padding="10,0"
                            FontSize="12" FontWeight="Medium">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PosButtonBase}">
                                <Setter Property="Background"       Value="Transparent"/>
                                <Setter Property="Foreground"       Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="BorderBrush"      Value="{DynamicResource InputBorderBrush}"/>
                                <Setter Property="BorderThickness"  Value="0.5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bdr"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="5"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                    <Setter TargetName="Bdr" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{Binding NewInvoiceLabel}" FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ─── CONTENT ROW: Products | Cart ─── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- ════ PRODUCTS PANEL ════ -->
                <Grid Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Search -->
                        <RowDefinition Height="Auto"/>   <!-- Categories -->
                        <RowDefinition Height="*"/>      <!-- Grid -->
                    </Grid.RowDefinitions>

                    <!-- Search bar (above categories) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource BgPrimaryBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,0,0,0.5"
                            Padding="14,10">
                        <Border Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0.5"
                                CornerRadius="8"
                                Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Search icon -->
                                <Viewbox Grid.Column="0" Width="15" Height="15" Margin="12,0,8,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconSearch}"
                                          Fill="{DynamicResource TextTertiaryBrush}" Stretch="Fill"/>
                                </Viewbox>
                                <!-- Search input -->
                                <TextBox x:Name="SearchBox"
                                         Grid.Column="1"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         CaretBrush="{DynamicResource AccentBrush}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Segoe UI"
                                         PreviewTextInput="SearchBox_OnPreviewTextInput"
                                         PreviewKeyDown="SearchBox_OnPreviewKeyDown"
                                         LostKeyboardFocus="SearchBox_OnLostKeyboardFocus">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      VerticalAlignment="Center"
                                                                      Background="Transparent"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <!-- Divider -->
                                <Border Grid.Column="2" Width="0.5" Background="{DynamicResource PanelBorderBrush}"
                                        Margin="4,6" VerticalAlignment="Stretch"/>
                                <!-- Barcode button -->
                                <Button Grid.Column="3" Background="Transparent" BorderThickness="0"
                                        Margin="6,0,10,0" Cursor="Hand"
                                        FocusVisualStyle="{x:Null}"
                                        Command="{Binding PriceCheckCommand}"
                                        ToolTip="{Binding ScanToolTip}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="14" Height="14" Margin="0,0,5,0">
                                            <Path Data="{StaticResource IconBarcode}"
                                                  Fill="{DynamicResource TextSecondaryBrush}" Stretch="Fill"/>
                                        </Viewbox>
                                        <TextBlock Text="{Binding ScanLabel}" FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Category bar (pills) -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource BgPrimaryBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,0,0,0.5">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden"
                                      Padding="12,8">
                            <ItemsControl ItemsSource="{Binding CategoryFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,6,0"
                                                Command="{Binding DataContext.FilterByCategoryCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PosButtonBase}">
                                                    <Setter Property="Background"       Value="Transparent"/>
                                                    <Setter Property="Foreground"       Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Setter Property="BorderBrush"      Value="{DynamicResource PanelBorderBrush}"/>
                                                    <Setter Property="BorderThickness"  Value="0.5"/>
                                                    <Setter Property="Padding"          Value="13,4"/>
                                                    <Setter Property="FontSize"         Value="12"/>
                                                    <Setter Property="FontWeight"       Value="Medium"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bdr"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="20"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bdr" Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Product grid (WrapPanel of cards) -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel Margin="10,10,10,10" Orientation="Horizontal">
                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center"
                                        Visibility="{Binding IsCartEmpty, Converter={StaticResource BoolToVis}}">
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Product Card -->
                                        <Button Width="148" Margin="5"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}"
                                                Command="{Binding DataContext.AddProductToCartCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Border x:Name="CardBdr"
                                                                Background="{DynamicResource BgPrimaryBrush}"
                                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                                BorderThickness="0.5"
                                                                CornerRadius="10">
                                                            <StackPanel>
                                                                <!-- Image / initials area -->
                                                                <Border Height="118"
                                                                        CornerRadius="10,10,0,0"
                                                                        ClipToBounds="True"
                                                                        Background="{DynamicResource BgSecondaryBrush}">
                                                                    <Grid>
                                                                        <!-- Initials (shown when no image OR images off) -->
                                                                        <Border Background="{DynamicResource AccentLightBrush}">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <!-- If image exists AND images are ON: hide placeholder -->
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding ImagePath, Converter={StaticResource HasImageVis}}" Value="Visible"/>
                                                                                                <Condition Binding="{Binding DataContext.ShowProductImages, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding Name, Converter={StaticResource ToInitials}}"
                                                                                       FontSize="38" FontWeight="Bold"
                                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <!-- Actual image (shown when image exists AND images ON) -->
                                                                        <Image Stretch="UniformToFill">
                                                                            <Image.Style>
                                                                                <Style TargetType="Image">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding ImagePath, Converter={StaticResource HasImageVis}}" Value="Visible"/>
                                                                                                <Condition Binding="{Binding DataContext.ShowProductImages, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                            <Setter Property="Source" Value="{Binding ImagePath, Converter={StaticResource FileToImg}}"/>
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Image.Style>
                                                                        </Image>
                                                                    </Grid>
                                                                </Border>
                                                                <!-- Text area -->
                                                                <StackPanel Margin="10,8,10,10">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="12" FontWeight="Medium"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                               TextWrapping="Wrap"
                                                                               MaxHeight="34"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N2}}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                               Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Low-stock badge -->
                                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                Background="{DynamicResource DangerBrush}"
                                                                CornerRadius="5" Padding="5,2"
                                                                Margin="0,8,8,0"
                                                                Visibility="{Binding QuantityOnHand,
                                                                    Converter={StaticResource LowStockVis}}">
                                                            <TextBlock Text="{Binding DataContext.LowStockLabel, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CardBdr" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Opacity" Value="0.80"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </ScrollViewer>

                </Grid>

                <!-- ════ CART PANEL ════ -->
                <Border Grid.Column="1"
                        Background="{DynamicResource BgPrimaryBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0.5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- Customer row -->
                            <RowDefinition Height="*"/>      <!-- Cart items -->
                            <RowDefinition Height="Auto"/>   <!-- Note / discount row -->
                            <RowDefinition Height="Auto"/>   <!-- Numpad strip -->
                            <RowDefinition Height="Auto"/>   <!-- Totals -->
                            <RowDefinition Height="Auto"/>   <!-- Print lang -->
                            <RowDefinition Height="Auto"/>   <!-- Action buttons -->
                        </Grid.RowDefinitions>

                        <!-- Customer row -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,0,0.5"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Walk-in avatar -->
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            Background="{DynamicResource BgSecondaryBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="0.5">
                                        <TextBlock Text="WK" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding WalkInCustomerLabel}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding InvoiceStatusLabel}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Cart icon with item count badge -->
                                <Border Grid.Column="1"
                                        Width="34" Height="34" CornerRadius="7"
                                        Background="{DynamicResource BgPrimaryBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0.5"
                                        Cursor="Hand">
                                    <Grid>
                                        <Viewbox Width="17" Height="17">
                                            <Path Data="{StaticResource IconCart}"
                                                  Fill="{DynamicResource TextSecondaryBrush}" Stretch="Fill"/>
                                        </Viewbox>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,-4,-4,0"
                                                MinWidth="15" Height="15"
                                                CornerRadius="8"
                                                Background="{DynamicResource AccentBrush}"
                                                Padding="2,0">
                                            <TextBlock Text="{Binding CartLines.Count}"
                                                       FontSize="8" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Cart items (expandable rows) -->
                        <Grid Grid.Row="1">
                            <!-- Empty state -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding IsCartEmpty, Converter={StaticResource BoolToVis}}">
                                <Viewbox Width="32" Height="32" Opacity="0.35">
                                    <Path Data="{StaticResource IconCart}"
                                          Fill="{DynamicResource TextSecondaryBrush}" Stretch="Fill"/>
                                </Viewbox>
                                <TextBlock Text="{Binding EmptyCartLabel}" FontSize="13"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Items list -->
                            <ListBox ItemsSource="{Binding CartLines}"
                                     SelectedItem="{Binding SelectedCartLine}"
                                     Background="{DynamicResource BgPrimaryBrush}"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Visibility="{Binding IsCartNotEmpty, Converter={StaticResource BoolToVis}}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="0,0,0,0.5">
                                            <StackPanel>
                                                <!-- Main row -->
                                                <Grid Height="44" Margin="12,0,10,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="58"/>
                                                        <ColumnDefinition Width="26"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Chevron -->
                                                    <Grid Grid.Column="0" VerticalAlignment="Center" Width="14" Height="14">
                                                        <Path x:Name="ChevronR"
                                                              Data="{StaticResource IconChevronRight}"
                                                              Fill="{DynamicResource TextTertiaryBrush}"
                                                              Stretch="Fill"/>
                                                        <Path x:Name="ChevronD"
                                                              Data="{StaticResource IconChevronDown}"
                                                              Fill="{DynamicResource AccentBrush}"
                                                              Stretch="Fill"
                                                              Visibility="Collapsed"/>
                                                    </Grid>

                                                    <!-- Product name -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="4,0,4,0"/>

                                                    <!-- Qty label -->
                                                    <TextBlock Grid.Column="2"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,6,0">
                                                        <Run Text="×"/>
                                                        <Run Text="{Binding Quantity, StringFormat={}{0:N0}}"/>
                                                    </TextBlock>

                                                    <!-- Line total -->
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding LineTotal, StringFormat={}{0:N2}}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextAlignment="Right"
                                                               VerticalAlignment="Center"/>

                                                    <!-- Remove -->
                                                    <Button Grid.Column="4" Width="22" Height="22"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand" FocusVisualStyle="{x:Null}"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveLineCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bdr" Background="{TemplateBinding Background}"
                                                                        CornerRadius="4">
                                                                    <Viewbox Width="11" Height="11">
                                                                        <Path Data="{StaticResource IconX}"
                                                                              Fill="{DynamicResource TextTertiaryBrush}"
                                                                              Stretch="Fill"/>
                                                                    </Viewbox>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource DangerBgBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>

                                                        <!-- Expanded controls (qty +/- and discount) -->
                                                <Border x:Name="ExpandPanel"
                                                        Visibility="Collapsed"
                                                        Background="{DynamicResource AccentLightBrush}"
                                                        BorderBrush="{DynamicResource AccentMidBrush}"
                                                        BorderThickness="0,0.5,0,0"
                                                        Padding="36,8,14,12">
                                                    <StackPanel>
                                                        <!-- Row 1: Qty control + unit price -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <TextBlock Text="{Binding DataContext.QtyLabel, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <Border BorderBrush="{DynamicResource InputBorderBrush}"
                                                                    BorderThickness="0.5" CornerRadius="6"
                                                                    Background="{DynamicResource BgPrimaryBrush}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Content="−" Style="{StaticResource QtyButton}"
                                                                            Command="{Binding DataContext.DecreaseLineQtyCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"/>
                                                                    <TextBlock Width="38"
                                                                               Text="{Binding Quantity, StringFormat={}{0:N1}}"
                                                                               TextAlignment="Center"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               FontFamily="Courier New"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                               VerticalAlignment="Center"/>
                                                                    <Button Content="+" Style="{StaticResource QtyButton}"
                                                                            Command="{Binding DataContext.IncreaseLineQtyCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" Margin="10,0,0,0">
                                                                <Run Text="@ "/>
                                                                <Run Text="{Binding UnitPrice, StringFormat={}{0:N2}}"/>
                                                                <Run Text="{Binding DataContext.EachLabel, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <!-- Row 2: Discount input -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DataContext.DiscountLabel, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <Border BorderBrush="{DynamicResource InputBorderBrush}"
                                                                    BorderThickness="0.5" CornerRadius="6"
                                                                    Background="{DynamicResource BgPrimaryBrush}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <!-- % prefix -->
                                                                    <Border Width="22" Height="28"
                                                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                                                            BorderThickness="0,0,0.5,0">
                                                                        <TextBlock Text="%" FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <!-- Discount % bound to ViewModel-level DiscountInput (syncs on selection) -->
                                                                    <TextBox Width="44" Height="28"
                                                                             Text="{Binding DataContext.DiscountInput,
                                                                                    RelativeSource={RelativeSource AncestorType=ListBox},
                                                                                    UpdateSourceTrigger=PropertyChanged}"
                                                                             FontSize="12" FontFamily="Courier New"
                                                                             TextAlignment="Center"
                                                                             BorderThickness="0"
                                                                             Background="Transparent"
                                                                             VerticalContentAlignment="Center"
                                                                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                    <!-- Apply ✓ -->
                                                                    <Button Width="28" Height="28"
                                                                            Background="{DynamicResource AccentBrush}"
                                                                            Foreground="White"
                                                                            BorderThickness="0"
                                                                            FontSize="13"
                                                                            Cursor="Hand"
                                                                            FocusVisualStyle="{x:Null}"
                                                                            Command="{Binding DataContext.SetLineDiscountCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                            CommandParameter="{Binding}">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="Bdr"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        CornerRadius="0,5,5,0">
                                                                                    <TextBlock Text="✓"
                                                                                               Foreground="White"
                                                                                               FontSize="13"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource AccentDarkBrush}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Border>
                                                            <!-- Current discount hint -->
                                                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DiscountPercent}" Value="0">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <Run Text="("/>
                                                                <Run Text="{Binding DiscountPercent, StringFormat={}{0:N0}}"/>
                                                                <Run Text="{Binding DataContext.DiscountAppliedSuffix, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                                                           Path=IsSelected}"
                                                         Value="True">
                                                <Setter TargetName="ExpandPanel" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ChevronR"    Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="ChevronD"    Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- Note / discount row -->
                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0.5,0,0"
                                Padding="12,6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        Padding="2" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                                        <Path Data="{StaticResource IconNote}"
                                                              Fill="{DynamicResource TextSecondaryBrush}" Stretch="Fill"/>
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding AddNoteLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Border Width="0.5" Background="{DynamicResource PanelBorderBrush}"
                                        Margin="12,2" VerticalAlignment="Stretch"/>
                                <Button Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        Command="{Binding RefundSaleCommand}"
                                        Padding="2" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                                        <Path Data="{StaticResource IconDiscount}"
                                                              Fill="{DynamicResource TextSecondaryBrush}" Stretch="Fill"/>
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding RefundLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Numpad strip (always visible, horizontal compact) -->
                        <Border Grid.Row="3"
                                Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0.5,0,0"
                                Padding="12,6,12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: label + display -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding QtyWeightLabel}" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               Margin="0,0,0,4"/>
                                    <Border Background="{DynamicResource BgPrimaryBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="0.5"
                                            CornerRadius="5"
                                            Padding="8,5">
                                        <TextBlock Text="{Binding QtyInput}"
                                                   FontSize="16" FontWeight="Medium"
                                                   FontFamily="Courier New"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextAlignment="Right"
                                                   HorizontalAlignment="Stretch"/>
                                    </Border>
                                </StackPanel>

                                <!-- Right: 6×2 numpad -->
                                <UniformGrid Grid.Column="1" Columns="6" Rows="2">
                                    <Button Content="7" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="7"/>
                                    <Button Content="8" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="8"/>
                                    <Button Content="9" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="9"/>
                                    <Button Content="4" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="4"/>
                                    <Button Content="5" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="5"/>
                                    <Button Content="6" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="6"/>
                                    <Button Content="1" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="1"/>
                                    <Button Content="2" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="2"/>
                                    <Button Content="3" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="3"/>
                                    <Button Content="." Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="."/>
                                    <Button Content="0" Style="{StaticResource NumpadButton}" Command="{Binding NumpadPressCommand}" CommandParameter="0"/>
                                    <Button Content="⌫" Foreground="{DynamicResource DangerBrush}"
                                            Style="{StaticResource NumpadButton}"
                                            Command="{Binding NumpadBackspaceCommand}"/>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!-- Totals -->
                        <Border Grid.Row="4"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0.5,0,0"
                                Padding="14,10,14,8">
                            <StackPanel>
                                <!-- Subtotal row -->
                                <Grid Margin="0,0,0,5">
                                    <TextBlock Text="{Binding SubtotalLabel}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N2}}"
                                               FontSize="12" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                                <!-- VAT row — label is editable so cashier can change the rate -->
                                <Grid Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TaxLabelPrefix}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Editable tax % field -->
                                        <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="0.5" CornerRadius="4"
                                                Background="{DynamicResource BgSecondaryBrush}"
                                                Margin="2,0">
                                            <TextBox Width="34" Height="18"
                                                     Text="{Binding TaxPercent, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}"
                                                     FontSize="11" FontFamily="Courier New"
                                                     TextAlignment="Center"
                                                     BorderThickness="0" Background="Transparent"
                                                     VerticalContentAlignment="Center"
                                                     Foreground="{DynamicResource TextPrimaryBrush}">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Return"
                                                                Command="{Binding SetInvoiceTaxCommand}"
                                                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=TextBox}, Path=Text}"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </Border>
                                        <TextBlock Text="%)" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TaxAmount, StringFormat={}{0:N2}}"
                                               FontSize="12" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Grand total -->
                                <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0.5,0,0" Margin="0,6,0,0" Padding="0,6,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding TotalLabel}" FontSize="19" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Total, StringFormat={}{0:N2}}"
                                                   FontSize="19" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Print language pills -->
                        <Border Grid.Row="5"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0.5,0,0"
                                Padding="14,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LanguageLabel}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ToggleButton Content="AR" Style="{StaticResource LangPillButton}"
                                              IsChecked="{Binding IsUiLanguageArabic, Mode=OneWay}"
                                              Command="{Binding SetUiLanguageCommand}"
                                              CommandParameter="ar"
                                              Margin="0,0,4,0"/>
                                <ToggleButton Content="EN" Style="{StaticResource LangPillButton}"
                                              IsChecked="{Binding IsUiLanguageEnglish, Mode=OneWay}"
                                              Command="{Binding SetUiLanguageCommand}"
                                              CommandParameter="en"
                                              Margin="0,0,4,0"/>
                                <ToggleButton Content="HE" Style="{StaticResource LangPillButton}"
                                              IsChecked="{Binding IsUiLanguageHebrew, Mode=OneWay}"
                                              Command="{Binding SetUiLanguageCommand}"
                                              CommandParameter="he"/>
                            </StackPanel>
                        </Border>

                        <!-- Action buttons -->
                        <Grid Grid.Row="6" Margin="12,8,12,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.6*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Hold/Resume -->
                            <Button Grid.Column="0"
                                    Height="44"
                                    Command="{Binding HoldResumeCommand}"
                                    ToolTip="{Binding HoldResumeToolTip}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PosButtonBase}">
                                        <Setter Property="Background"       Value="Transparent"/>
                                        <Setter Property="Foreground"       Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="BorderBrush"      Value="{DynamicResource InputBorderBrush}"/>
                                        <Setter Property="BorderThickness"  Value="0.5"/>
                                        <Setter Property="FontWeight"       Value="SemiBold"/>
                                        <Setter Property="Padding"          Value="10,0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveTabIsHeld}" Value="True">
                                                <Setter Property="Background"  Value="{DynamicResource WarnBgBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WarnBrush}"/>
                                                <Setter Property="Foreground"  Value="{DynamicResource WarnBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                        <Path Data="{StaticResource IconPause}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Fill"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding ActiveTabIsHeld, Converter={StaticResource BoolToVis}}"
                                               Visibility="Collapsed"/>
                                    <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Text="{Binding HoldResumeActionLabel}"/>
                                </StackPanel>
                            </Button>

                            <!-- Proceed (Pay) -->
                            <Button Grid.Column="2"
                                    Height="44"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding CompleteSaleCommand}"
                                    IsEnabled="{Binding IsCartNotEmpty}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,7,0">
                                        <Path Data="{StaticResource IconCheck}"
                                              Fill="White" Stretch="Fill"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding ProceedLabel}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                    </Grid>
                </Border>

            </Grid>
        </Grid>

    </Grid>
</Window>
