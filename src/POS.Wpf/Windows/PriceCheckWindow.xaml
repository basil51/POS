<Window x:Class="POS.Wpf.Windows.PriceCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:POS.Wpf.Converters"
        Title="Price Check"
        Height="480" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        Background="{StaticResource BgPrimaryBrush}">

    <Window.Resources>
        <conv:FilePathToImageConverter         x:Key="FileToImg"/>
        <conv:StringToInitialsConverter        x:Key="ToInitials"/>
        <conv:ImagePathToVisibilityConverter   x:Key="HasImageVis"/>
        <conv:ImagePathToVisibilityConverter   x:Key="NoImageVis" Inverted="True"/>
        <conv:LowStockToVisibilityConverter    x:Key="LowStockVis"/>
        <BooleanToVisibilityConverter          x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Price Check"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,12"/>

            <!-- Search box -->
            <TextBox Grid.Row="1"
                     x:Name="SearchBox"
                     Style="{StaticResource PosTextBox}"
                     Margin="0,0,0,10"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Resources>
                    <Style TargetType="Border" BasedOn="{x:Null}"/>
                </TextBox.Resources>
            </TextBox>

            <!-- Results area -->
            <Grid Grid.Row="2">

                <!-- Placeholder (no search yet) -->
                <StackPanel x:Name="PlaceholderPanel"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="32"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Type a product name or scan a barcode"
                               FontSize="12" TextAlignment="Center"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                </StackPanel>

                <!-- No results -->
                <StackPanel x:Name="NoResultsPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No product found"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Results list + detail card -->
                <Grid x:Name="ResultsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Matching products list -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0.5"
                            CornerRadius="6"
                            Margin="0,0,0,10"
                            ClipToBounds="True">
                        <ListBox x:Name="ResultsList"
                                 BorderThickness="0"
                                 Background="{StaticResource BgPrimaryBrush}"
                                 SelectionChanged="ResultsList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                 Color="#ECFDF5"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                                 Color="#111827"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                                 Color="#ECFDF5"/>
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="12,10">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel LastChildFill="False">
                                        <!-- Initials / image -->
                                        <Border DockPanel.Dock="Left"
                                                Width="30" Height="30"
                                                CornerRadius="4"
                                                Background="{StaticResource AccentLightBrush}"
                                                Margin="0,0,10,0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="{Binding Name, Converter={StaticResource ToInitials}}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding ImagePath, Converter={StaticResource NoImageVis}}"/>
                                                <Image Source="{Binding ImagePath, Converter={StaticResource FileToImg}}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding ImagePath, Converter={StaticResource HasImageVis}}"/>
                                            </Grid>
                                        </Border>
                                        <!-- Name -->
                                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock x:Name="BarcodeRow"
                                                       Text="{Binding Barcode, StringFormat='Barcode: {0}'}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Barcode}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Barcode}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Price -->
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Price, StringFormat={}{0:N2}}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Detail card for selected product -->
                    <Border Grid.Row="1"
                            x:Name="DetailCard"
                            Visibility="Collapsed"
                            Background="{StaticResource AccentLightBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="0.5"
                            CornerRadius="8"
                            Padding="14,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="DetailName"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock x:Name="DetailStock"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <!-- Low-stock warning inline -->
                                    <Border x:Name="LowStockBadge"
                                            Visibility="Collapsed"
                                            Background="{StaticResource DangerBrush}"
                                            CornerRadius="4" Padding="5,1" Margin="6,0,0,0">
                                        <TextBlock Text="LOW STOCK"
                                                   FontSize="8" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="DetailBarcode"
                                           FontSize="10"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="DetailPrice"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- Divider -->
            <Separator Grid.Row="3"
                       Background="{StaticResource PanelBorderBrush}"
                       Margin="-20,10,-20,10"/>

            <!-- Footer buttons -->
            <DockPanel Grid.Row="4" LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="Close"
                        Click="Close_Click"
                        Style="{StaticResource GhostButton}"
                        Width="80"/>
                <Button DockPanel.Dock="Right"
                        x:Name="AddButton"
                        Content="＋ Add to Invoice"
                        Click="AddToInvoice_Click"
                        Style="{StaticResource AccentButton}"
                        IsEnabled="False"/>
            </DockPanel>

        </Grid>
    </Border>
</Window>
