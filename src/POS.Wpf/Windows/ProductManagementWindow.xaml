<Window x:Class="POS.Wpf.Windows.ProductManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Products &amp; categories"
        Height="520"
        Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="New category:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,8,0" />
            <Button Content="Add category" Command="{Binding AddCategoryCommand}" Margin="0,0,16,0" />
            <Button Content="Add product" Command="{Binding AddProductCommand}" Margin="0,0,8,0" />
            <Button Content="Edit" Command="{Binding EditProductCommand}" Margin="0,0,8,0" />
            <Button Content="Delete" Command="{Binding DeleteProductCommand}" />
        </StackPanel>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120" />
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=N2}" Width="80" />
                <DataGridTextColumn Header="Qty" Binding="{Binding QuantityOnHand, StringFormat=N2}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
