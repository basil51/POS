<Window x:Class="POS.Wpf.Windows.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Payment"
        Height="300" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        Background="{StaticResource BgPrimaryBrush}">

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Process Payment"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Total display -->
            <Border Grid.Row="1"
                    Background="{StaticResource AccentLightBrush}"
                    CornerRadius="8" Padding="14,10"
                    Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Total due"
                               FontSize="12"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               x:Name="TotalLabel"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"/>
                </DockPanel>
            </Border>

            <!-- Cash received label -->
            <TextBlock Grid.Row="2"
                       Text="Cash received"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>

            <!-- Cash input -->
            <TextBox Grid.Row="3"
                     x:Name="CashBox"
                     Style="{StaticResource PosTextBox}"
                     TextAlignment="Right"
                     FontSize="18" FontWeight="Medium"
                     Margin="0,0,0,8"
                     TextChanged="CashBox_TextChanged"/>

            <!-- Change row -->
            <Border Grid.Row="4" VerticalAlignment="Top">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Change"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               x:Name="ChangeLabel"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource AccentBrush}"/>
                </DockPanel>
            </Border>

            <!-- Buttons -->
            <Border Grid.Row="5"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Margin="-20,0,-20,0"
                    Padding="20,12,20,0">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Left"
                            Content="Cancel"
                            Click="Cancel_Click"
                            Style="{StaticResource GhostButton}"
                            Width="80"/>
                    <Button DockPanel.Dock="Right"
                            Content="Complete"
                            Click="Ok_Click"
                            Style="{StaticResource AccentButton}"
                            Width="100"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
