<Window x:Class="POS.Wpf.Windows.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Daily Sales Report"
        Height="620" Width="660"
        ResizeMode="CanResizeWithGrip"
        MinHeight="500" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgTertiaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="Daily Sales Report"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Date picker -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="Date:"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="ReportDate"
                                FontSize="12"
                                Width="140"
                                VerticalAlignment="Center"
                                SelectedDateChanged="ReportDate_Changed"/>
                    <Button Content="🔄  Refresh"
                            Click="Refresh_Click"
                            Style="{StaticResource GhostButton}"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Summary cards -->
        <Border Grid.Row="1"
                Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <UniformGrid Columns="4" Rows="1">

                <Border Margin="4" Background="{StaticResource AccentLightBrush}"
                        CornerRadius="8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Revenue" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CardRevenue" Text="0.00"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <Border Margin="4" Background="{StaticResource InfoBgBrush}"
                        CornerRadius="8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Invoices" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InfoBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CardInvoices" Text="0"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource InfoBrush}"/>
                    </StackPanel>
                </Border>

                <Border Margin="4" Background="{StaticResource BgSecondaryBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0.5"
                        CornerRadius="8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Items Sold" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CardItems" Text="0"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Margin="4" Background="{StaticResource BgSecondaryBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0.5"
                        CornerRadius="8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Avg. Sale" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CardAvg" Text="0.00"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>
        </Border>

        <!-- Two-column detail area -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Top Products -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPrimaryBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0.5"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="Top Products"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             x:Name="TopProductsList"
                             BorderThickness="0"
                             Background="{StaticResource BgPrimaryBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="12,9">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="{Binding Rank, StringFormat=#{0}}"
                                               FontSize="10" FontWeight="Bold"
                                               Width="22"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="{Binding Name}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="120"
                                               VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Revenue, StringFormat={}{0:N2}}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding QtySold, StringFormat=×{0:N0}}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Invoices list -->
            <Border Grid.Column="2"
                    Background="{StaticResource BgPrimaryBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0.5"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="Invoices"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             x:Name="InvoicesList"
                             BorderThickness="0"
                             Background="{StaticResource BgPrimaryBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="12,9">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding InvoiceNumber}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Time}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Total, StringFormat={}{0:N2}}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           x:Name="FooterText"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Click="Close_Click"
                        Style="{StaticResource GhostButton}"
                        Width="80"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
