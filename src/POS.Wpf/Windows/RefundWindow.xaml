<Window x:Class="POS.Wpf.Windows.RefundWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refund Sale"
        Height="460" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}">

    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Refund Sale"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Select a completed sale to refund. Stock will be restored."
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Warning banner -->
            <Border Grid.Row="1"
                    Background="#FEF3C7"
                    BorderBrush="#F59E0B"
                    BorderThickness="0.5"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,0,0,10">
                <TextBlock Text="⚠  This action cannot be undone. The invoice will be marked Cancelled and all item quantities returned to stock."
                           FontSize="11"
                           Foreground="#92400E"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- List of recent paid invoices -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0.5"
                    CornerRadius="6"
                    ClipToBounds="True">
                <ListBox x:Name="InvoiceList"
                         BorderThickness="0"
                         Background="{StaticResource BgPrimaryBrush}"
                         SelectionChanged="InvoiceList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"       Color="#FEF3C7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"   Color="#111827"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FEF3C7"/>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="12,10">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected"   Value="True">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding InvoiceNumber}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding PaidAt}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding Total, StringFormat={}{0:N2}}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource DangerBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <!-- Empty state -->
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Style.Triggers>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <Border Background="{StaticResource BgPrimaryBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="No recent paid invoices found."
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,40"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                </ListBox>
            </Border>

            <!-- Divider -->
            <Separator Grid.Row="3"
                       Background="{StaticResource PanelBorderBrush}"
                       Margin="-20,10,-20,10"/>

            <!-- Footer -->
            <DockPanel Grid.Row="4" LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="Cancel"
                        Click="Cancel_Click"
                        Style="{StaticResource GhostButton}"
                        Width="80"/>
                <Button DockPanel.Dock="Right"
                        x:Name="RefundButton"
                        Content="↩  Process Refund"
                        Click="Refund_Click"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PosButtonBase}">
                            <Setter Property="Background"     Value="{StaticResource DangerBrush}"/>
                            <Setter Property="Foreground"     Value="White"/>
                            <Setter Property="BorderBrush"    Value="{StaticResource DangerBrush}"/>
                            <Setter Property="BorderThickness" Value="0.5"/>
                            <Setter Property="Padding"        Value="14,8"/>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>

        </Grid>
    </Border>
</Window>
