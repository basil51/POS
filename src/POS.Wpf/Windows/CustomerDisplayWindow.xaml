<Window x:Class="POS.Wpf.Windows.CustomerDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Display — SmartPOS"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#111827"
        Width="480" Height="320"
        Topmost="True"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#1F2937"
                Padding="20,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           FontSize="16" FontWeight="SemiBold">
                    <Run Text="Smart" Foreground="White"/>
                    <Run Text="POS" Foreground="#10B981"/>
                </TextBlock>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="TimeText"
                           FontSize="13"
                           Foreground="#9CA3AF"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Cart area -->
        <Grid Grid.Row="1">

            <!-- Idle / no items -->
            <StackPanel x:Name="IdlePanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Welcome!"
                           FontSize="28" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Your items will appear here"
                           FontSize="13"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Items list -->
            <ItemsControl x:Name="LinesList"
                          Visibility="Collapsed"
                          Margin="0,0,0,0">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#374151"
                                BorderThickness="0,0,0,0.5"
                                Padding="20,10">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           MaxWidth="260"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding Quantity, StringFormat=  × {0:N0}}"
                                           FontSize="12"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding LineTotal, StringFormat={}{0:N2}}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#10B981"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>

        <!-- Total footer -->
        <Border Grid.Row="2"
                Background="#1F2937"
                Padding="20,14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="TOTAL"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#9CA3AF"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="TotalText"
                           Text="0.00"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#10B981"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
